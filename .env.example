# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real credentials.

# NASA Earthdata Login  (https://urs.earthdata.nasa.gov)
# Required for OPERA (notebook 02) and HyP3 (notebook 03).
EARTHDATA_USERNAME=your_username
EARTHDATA_PASSWORD=your_password

# Google Earth Engine cloud project ID  (https://console.cloud.google.com)
# Required for Sentinel-2 retrieval (notebook 01).
# Create a project at console.cloud.google.com and enable the Earth Engine API.
# Run ee.Authenticate() once in a terminal or notebook, then set this value.
GEE_PROJECT=your-gee-project-id
